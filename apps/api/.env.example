# ─────────────────────────────────────────────────────────────────────────
# Servora API — environment (Tech-Stack §10)
#
# Copy to `.env` and adjust. Only the infra/bootstrap values are REQUIRED.
# Third-party provider keys are OPTIONAL: at runtime the API reads each key
# from the DB first (Admin → Integrations, encrypted) and falls back to the
# env var below only when unset. Leave them blank to run locally with stubs.
# ─────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# ── Core infrastructure (REQUIRED) ──
# Matches docker-compose.yml (host ports 5433/6380 to avoid clashing with a
# local Postgres/Redis already on 5432/6379).
DATABASE_URL=postgresql://servora:servora@localhost:5433/servora?schema=public
REDIS_URL=redis://localhost:6380

# ── Auth (REQUIRED) — use long random strings in real environments ──
JWT_ACCESS_SECRET=dev-access-secret-change-me-please
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── Encryption / KMS (SECURITY.md A1) ──
# local  → dev shim: a git-ignored keyfile under .keys/ is auto-generated.
# aws    → wrap/unwrap data keys via a KMS CMK (set KMS_AWS_KEY_ID + AWS_REGION).
KMS_PROVIDER=local
KMS_KEYFILE=.keys/local-kms.json
# KMS_AWS_KEY_ID=arn:aws:kms:ap-south-1:...:key/...
# AWS_REGION=ap-south-1
# Optional: if set, the local keyfile's first data key is derived from this
# (lets a team share a deterministic dev key). Not used when KMS_PROVIDER=aws.
INTEGRATIONS_ENCRYPTION_KEY=dev-integrations-encryption-key-change-me

# ── Third-party provider keys (OPTIONAL — DB-first, env-fallback) ──
# Surepass — GST + identity KYC
SUREPASS_TOKEN=
SUREPASS_BASE_URL=https://kyc-api.surepass.io

# Razorpay — customer payments (authorize at booking, capture at completion)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# RazorpayX — engineer payouts
RAZORPAYX_KEY=
RAZORPAYX_SECRET=

# Google Maps Platform — geocoding, distance, directions
GOOGLE_MAPS_API_KEY=

# Firebase Cloud Messaging — push notifications (JSON service account)
FCM_SERVICE_ACCOUNT=

# MSG91 — transactional SMS + OTP
MSG91_AUTH_KEY=

# AWS S3 — proof photos & KYC documents
AWS_ACCESS_KEY_ID=
AWS_SECRET=
S3_BUCKET=

# Email — SES region or SendGrid key
SES_REGION=ap-south-1
SENDGRID_API_KEY=

# Sentry — error & performance monitoring
SENTRY_DSN=

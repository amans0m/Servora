{
  "name": "servora",
  "version": "1.0.0",
  "private": true,
  "description": "Servora — IT-services marketplace (monorepo root)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "api": "pnpm --filter @servora/api",
    "api:dev": "pnpm --filter @servora/api start:dev",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "2.9.18",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "overrides": {
      "multer@<2.1.1": ">=2.1.1",
      "@types/react": "18.3.12",
      "@types/react-dom": "18.3.1",
      "@xmldom/xmldom@<0.8.12": ">=0.8.12",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-r5fr-rjxr-66jc",
        "GHSA-34x7-hfp2-rc4v",
        "GHSA-8qq5-rm4j-mr97",
        "GHSA-83g3-92jg-28cx",
        "GHSA-qffp-2rhf-9h96",
        "GHSA-9ppj-qmqm-q256",
        "GHSA-r6q2-hw4h-h46w",
        "GHSA-h25m-26qc-wcjf",
        "GHSA-q4gf-8mx6-v5v3",
        "GHSA-8h8q-6873-q5fj",
        "GHSA-c4j6-fc7j-m34r",
        "GHSA-36qx-fr4f-26g5"
      ]
    }
  }
}
